# Entorno virtual de Python
venv/

# Caches y bytecode de Python
__pycache__/
*.pyc

# Checkpoints automáticos de Jupyter
.ipynb_checkpoints/

# Datos generados (se reproducen desde APIs públicas: USGS, JPL Horizons)
data/raw/*.csv
data/processed/*.csv

# Variables de entorno locales (claves, secretos)
.env

# Cache local de redes externas (USGS, Skyfield/JPL)
data/cache/

# Efemerides binarias descargadas (regenerables desde Skyfield)
*.bsp

# Build artifacts del paquete
src/*.egg-info/
*.egg-info/
build/
dist/

# Cache de pytest
.pytest_cache/
